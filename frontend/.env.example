# --- Lokalny development (npm run dev) ---
# Opcjonalnie; bez tego pliku używany jest http://127.0.0.1:8000
# VITE_API_BASE_URL=http://127.0.0.1:8000

# --- Produkcja (Netlify) ---
# Vite wstawia tę wartość W MOMENCIE BUILDU (nie w runtime).
# W Netlify: Site configuration → Environment variables → dodaj:
#   VITE_API_BASE_URL = https://twoja-aplikacja.onrender.com
# Następnie uruchom ponownie deploy (Clear cache and deploy).
VITE_API_BASE_URL=https://twoja-aplikacja.onrender.com
